# MongoDB connection (use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/tournament_manager

# Auth — generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# App URL — set to your Vercel domain in production (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name (optional)
APP_NAME=Tournament Manager

# SMTP (use a transactional email service like Resend, Postmark, or Mailgun in production)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tournament.app
