# ==============================================================================
# Copy this file to `.env` (for Docker/VPS deploy) or `.env.local` (local dev).
# Never commit the filled-in file — it is gitignored.
# ==============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL — set to your production domain. Inlined into the build (build arg).
NEXT_PUBLIC_APP_URL=https://tournaments.rafi.ninja
# App display name (optional)
APP_NAME=Tournament Manager

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL DEV (npm run dev): point straight at a Mongo you run yourself.
#   MONGODB_URI=mongodb://localhost:27017/tournament_manager
#
# DOCKER DEPLOY (docker compose): DO NOT set MONGODB_URI here — compose builds it
# from the bundled-Mongo credentials below as:
#   mongodb://${MONGO_USER}:${MONGO_PASS}@mongo:27017/${MONGO_DB}?authSource=admin
# NOTE: MONGO_USER/MONGO_PASS only take effect on the FIRST boot (empty volume).
# Changing them later does NOT update the running DB — rotate via mongosh
# (db.changeUserPassword) or delete the mongo_data volume to re-init (destroys data).
# Use a URL-safe password (letters/digits) — unescaped @ : / ? # break MONGODB_URI.
MONGO_USER=tournament
MONGO_PASS=change_me_to_a_long_random_password
MONGO_DB=tournament_manager

# ── SMTP (transactional email; use Resend/Postmark/Mailgun in production) ──────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tournament.app

# ── Docker / Traefik deploy (VPS) ─────────────────────────────────────────────
# Public host for the Traefik router rule.
APP_DOMAIN=tournaments.rafi.ninja
# Compose project + container name prefix (containers: <prefix>_app, <prefix>_mongo).
APP_PREFIX=tournament
# Shared Traefik settings — defaults already match this VPS; override only if different.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=le
# Optional: serve multiple hosts from one router/cert, e.g.
#   TRAEFIK_RULE=Host(`tournaments.rafi.ninja`) || Host(`www.tournaments.rafi.ninja`)
